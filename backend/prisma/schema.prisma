datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Member[]
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  website   String?
  industry  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members         Member[]
  businessProfile BusinessProfile?
  metrics         BusinessMetric[]
  sessions        ConversationSession[]
  analyses        AIAnalysis[]
}

model Member {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  role           Role         @default(MEMBER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model BusinessProfile {
  id             String       @id @default(uuid())
  organizationId String       @unique
  profileData    Json         // Flex JSON for description, goals, target, competitors
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model BusinessMetric {
  id             String       @id @default(uuid())
  organizationId String
  metricName     String       // e.g. "revenue", "profit_margin", "cac", "ltv"
  value          Float
  period         String       // "monthly", "quarterly", "yearly"
  timestamp      DateTime     // Used for historical trend and analytics queries
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ConversationSession {
  id             String       @id @default(uuid())
  organizationId String
  title          String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chats          ChatHistory[]
  agentMemories  AgentMemory[]
}

model ChatHistory {
  id             String              @id @default(uuid())
  sessionId      String
  role           String              // "user" | "assistant"
  content        String
  createdAt      DateTime            @default(now())

  session        ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model AgentMemory {
  id             String              @id @default(uuid())
  sessionId      String
  agentName      String              // e.g. "Finance", "Marketing"
  summary        String
  issues         Json                // Json array string[]
  recommendations Json               // Json array string[]
  confidence     Float
  rawJson        Json                // Complete structured JSON response from the agent
  createdAt      DateTime            @default(now())

  session        ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, agentName])
}

model AIAnalysis {
  id             String       @id @default(uuid())
  organizationId String
  analysisType   String       // e.g. "CEO_SUMMARY", "GROWTH_STRATEGY"
  results        Json
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
